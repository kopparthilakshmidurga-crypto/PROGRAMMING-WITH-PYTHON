class InsufficientFunds(Exception):
 pass
balance=1000
amount=int(input("Enter amount:"))
try:
 if amount>balance :
  raise InsufficientFunds("sorry amount is not sufficient")
 else:
  balance-=amount
  print("Withdraw successfull the remaining balance is :",balance)
except InsufficientFunds as e:
  print("ERROR:",e)
